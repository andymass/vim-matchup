Execute (Helper):
  function! TSActive()
    if !exists('*luaeval')
      return v:false
    endif
    return luaeval("vim and vim.treesitter and vim.treesitter.language and vim.treesitter.language.get_filetypes and (#vim.treesitter.language.get_filetypes('python') > 0)")
  endfunction

  if TSActive()
    Log 'nvim-treesitter active'
  else
    Log 'nvim-treesitter not active'
  endif

Given python (A python script):
  def F(x, y):
    if x == 1:
      return 1
    elif x == 2:
      if y == 5:
        pass
      elif y == 7:
        return 9
      else:
        return x
    else:
      return 3
    return 2

Execute (Logs):
  Log b:matchup_active_engines

# ----- outer if/elif/else -----

Before (Cursor):
  normal! 2gg^
  :sleep 50m\<cr>

Do (Move %):
  %
Then (Verify line):
  AssertEqual (TSActive() ? 4 : 2), line('.') 

Do (Move % twice):
  %%
Then (Verify line):
  AssertEqual (TSActive() ? 11 : 2), line('.') 

Do (Move % 3 times):
  %%%
Then (Verify line):
  AssertEqual (TSActive() ? 2 : 2), line('.') 

Do (Move % 4 times):
  %%%%
Then (Verify line):
  AssertEqual (TSActive() ? 4 : 2), line('.') 

# ----- inner if/elif/else -----

Before (Cursor):
  normal! 5gg^
  :sleep 50m\<cr>

Do (Inner: Move %):
  %
Then (Verify line):
  AssertEqual (TSActive() ? 7 : 5), line('.') 

Do (Inner: % 2 times):
  %%
Then (Verify line):
  AssertEqual (TSActive() ? 9 : 5), line('.') 

Do (Inner: % 3 times):
  %%%
Then (Verify line):
  AssertEqual (TSActive() ? 5 : 5), line('.') 

Do (Inner: % 4 times):
  %%%%
Then (Verify line):
  AssertEqual (TSActive() ? 7 : 5), line('.') 
